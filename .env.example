# Cadena de conexión de MongoDB Atlas (Free M0). Ver README.md para el paso a paso.
MONGO_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/prestamos_vr?retryWrites=true&w=majority

# Secreto para firmar las cookies de sesión (JWT). Usa una cadena larga y aleatoria.
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Credenciales del usuario administrador. Solo se usan la primera vez que arranca el
# servidor para crear el documento de Config si no existe todavía. Después el password
# se puede cambiar desde Configuración > Seguridad (queda guardado con hash en la DB).
ADMIN_USER=admi
ADMIN_PASS=12345

# Puerto para desarrollo local (server.js). Vercel ignora esta variable en producción.
PORT=3000
